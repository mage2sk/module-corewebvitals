<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Resource hints output (dns-prefetch, preconnect link tags) -->
        <referenceContainer name="after.body.start">
            <block class="Panth\CoreWebVitals\Block\ResourceHints"
                   name="panth.corewebvitals.resource.hints"
                   template="Panth_CoreWebVitals::resource-hints.phtml"
                   before="-"/>
        </referenceContainer>

        <!-- Core Web Vitals monitoring script -->
        <referenceContainer name="before.body.end">
            <block class="Panth\CoreWebVitals\Block\CoreWebVitals"
                   name="panth.corewebvitals.monitor"
                   template="Panth_CoreWebVitals::core-web-vitals.phtml"/>
        </referenceContainer>
    </body>
</page>
